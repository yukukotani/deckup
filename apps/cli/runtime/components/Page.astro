---
interface Props {
  title?: string;
  class?: string;
  layout?: string;
}

const { title, class: className, layout = "default" } = Astro.props;
---

<section
  class:list={["slida-slide", className]}
  data-slida-slide
  data-slida-layout={layout}
  aria-label={title ?? "Slide"}
>
  <slot />
</section>
