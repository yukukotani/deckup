{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "deckup-docs",
  "compatibility_date": "2026-07-07",
  "assets": {
    "directory": "./dist",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page",
  },
  "routes": [
    {
      "pattern": "deckup.yuku.dev",
      "custom_domain": true,
    },
  ],
}
