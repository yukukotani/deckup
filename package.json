{
  "name": "deckup",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp check && vp run -r test && vp run -r build",
    "dev": "vp run example#dev",
    "dev:web": "vp run @deckup/web#dev",
    "deploy:web": "vp run @deckup/web#deploy",
    "prepare": "vp config"
