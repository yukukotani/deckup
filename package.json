  "devDependencies": {
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "ignore"
    }
  },
  "packageManager": "pnpm@11.9.0"
}
