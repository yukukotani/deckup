---
import Page from "@slida/cli/page";
---

<Page title="Presentation title">
  <layout id="cover" />
  <h1>This is presentation title</h1>
  <p>This is presentation subtitle</p>
</Page>

<Page title="Section title">
  <layout id="section" />
  <h1>This is section title</h1>
</Page>

<Page title="Page title">
  <layout id="page" />
  <h1>This is page title</h1>
  <p>This is page content</p>
  <ul>
    <li>bullet</li>
    <li>list</li>
  </ul>
  <p>This is new paragraph</p>
  <ol>
    <li>number</li>
    <li>list</li>
  </ol>
</Page>

<Page title="Two-column page title">
  <layout id="two-column" />
  <h1>This is page title</h1>
  <p slot="left">This is left column content</p>
  <p slot="right">This is right column content</p>
</Page>

<Page title="Number page">
  <layout id="number" />
  <p>xx%</p>
  <p>This is number page</p>
</Page>

<Page title="Quote page">
  <layout id="quote" />
  <p>This is quote page</p>
  <p>- name</p>
</Page>

<Page title="Statement page">
  <layout id="statement" />
  <p>This is statement<br />page</p>
</Page>

<Page title="TypeScript code block">
  <layout id="page" />
  <h1>TypeScript code block</h1>
  <p>This slide shows a TypeScript code block in an Astro deck.</p>
  <pre><code>{`type Slide = {
  title: string;
  layout: "cover" | "page";
};

const slide: Slide = {
  title: "Hello TypeScript",
  layout: "page",
};`}</code></pre>
</Page>
